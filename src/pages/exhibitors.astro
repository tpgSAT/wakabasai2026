---
import Layout from '@layouts/Layout.astro';
import PageTitle from '@components/PageTitle.astro';
import Section from '@components/layout/Section.astro';
import ExhibitorsCard from '@components/ExhibitorsCard.astro';

import {exhibitors} from '@lib/exhibitors';

import exhibitorsTitleSVG from '@assets/exhibitors/title.svg';

const getCircleId = (name: string) => `circle-${encodeURIComponent(name.trim())}`;
---
<Layout title="出展団体一覧">
    <Section>
        <PageTitle titleSVG={exhibitorsTitleSVG} />
        <p class="text-body">若葉祭2026に出展する部活・サークルの一覧です。それぞれの企画については<a href="/#booth">こちら</a>をご確認ください。</p>
    </Section>
    <Section>
        <div class="filter-bar">
            <div class="filter-group filter-day">
                <span class="filter-label">開催日</span>
                <div class="filter-btn-wrapper">
                    <button class="filter-btn active" data-filter="day" data-value="4/10">4/10(金)</button>
                    <button class="filter-btn" data-filter="day" data-value="4/11">4/11(土)</button>
                </div>
            </div>
            <div class="filter-group filter-booth">
                <span class="filter-label">企画種別</span>
                <div class="filter-btn-wrapper">
                    <button class="filter-btn active" data-filter="booth" data-value="all">すべて</button>
                    <button class="filter-btn" data-filter="booth" data-value="サークルブース">サークルブース</button>
                    <button class="filter-btn" data-filter="booth" data-value="ワークショップ">ワークショップ</button>
                    <button class="filter-btn" data-filter="booth" data-value="ステージ企画">ステージ企画</button>
                </div>
            </div>
        </div>
        <div class="exhibitor-grid">
            {exhibitors.map((exhibitor, index) => (
                <div id={getCircleId(exhibitor.exhibitorName)} class="exhibitor-wrapper" data-days={exhibitor.days.join(",")} data-booths={exhibitor.booths.join(",")}>
                    <ExhibitorsCard key={index} {...exhibitor} />
                </div>
            ))}
        </div>
    </Section>
</Layout>

<script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const urlParams = new URLSearchParams(window.location.search);
    let activeDay = urlParams.get('day') ?? '4/10';
    let activeBooth = 'all';

    // Shuffle once per session, restore on subsequent visits
    const grid = document.querySelector('.exhibitor-grid')!;
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.exhibitor-wrapper'));
    const SESSION_KEY = 'exhibitor-order';
    const stored = sessionStorage.getItem(SESSION_KEY);

    if (stored) {
        const order: number[] = JSON.parse(stored);
        order.forEach(i => grid.appendChild(cards[i]));
    } else {
        const indices = cards.map((_, i) => i);
        for (let i = indices.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [indices[i], indices[j]] = [indices[j], indices[i]];
        }
        sessionStorage.setItem(SESSION_KEY, JSON.stringify(indices));
        indices.forEach(i => grid.appendChild(cards[i]));
    }

    function applyFilters() {
        document.querySelectorAll<HTMLElement>('.exhibitor-wrapper').forEach(card => {
            const days = card.dataset.days?.split(',') ?? [];
            const booths = card.dataset.booths?.split(',') ?? [];
            const dayMatch = activeDay === 'all' || days.includes(activeDay);
            const boothMatch = activeBooth === 'all' || booths.includes(activeBooth);
            card.style.display = dayMatch && boothMatch ? '' : 'none';
        });
    }

    buttons.forEach(btn => {
        btn.addEventListener('click', () => {
            const filter = btn.dataset.filter;
            const value = btn.dataset.value ?? 'all';
            if (filter === 'day') {
                activeDay = value;
                document.querySelectorAll('[data-filter="day"]').forEach(b => b.classList.remove('active'));
            } else {
                activeBooth = value;
                document.querySelectorAll('[data-filter="booth"]').forEach(b => b.classList.remove('active'));
            }
            btn.classList.add('active');
            applyFilters();
        });
    });

    const hashTargetId = window.location.hash.slice(1);
    const hashTarget = hashTargetId ? document.getElementById(hashTargetId) as HTMLElement | null : null;
    if (hashTarget && !urlParams.get('day')) {
        const targetDays = hashTarget.dataset.days?.split(',') ?? [];
        if (targetDays.includes('4/10')) {
            activeDay = '4/10';
        } else if (targetDays.includes('4/11')) {
            activeDay = '4/11';
        }
    }

    document.querySelectorAll<HTMLButtonElement>('[data-filter="day"]').forEach((button) => {
        button.classList.toggle('active', button.dataset.value === activeDay);
    });

    applyFilters();

    if (hashTarget) {
        hashTarget.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
</script>

<style>
    .filter-bar {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 24px;
    }

    .filter-day {
        gap: 0px;
    }

    .filter-day .filter-btn {
        width: 50%;
    }

    .filter-bar .filter-label{
        font-size: 15px;
        font-weight: 700;
        letter-spacing: 0.96px;
    }

    .filter-day .filter-btn-wrapper {
        margin-top: 8px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0px;
    }

    .filter-booth .filter-btn-wrapper {
        margin-top: 8px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 8px;
    }

    .filter-btn {
        padding: 8px 12px;
        font-size: 14px;
        font-family: inherit;
        font-weight: 700;
        letter-spacing: 0.96px;
        border: 1.5px solid var(--wakabasai-red);
        background: transparent;
        color: var(--wakabasai-red);
        cursor: pointer;
    }

    .filter-btn.active {
        background: var(--wakabasai-red);
        color: #fff;
    }

    .exhibitor-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 0 20px;
    }
</style>
