---
import Layout from '@layouts/Layout.astro';
import Section from '@components/layout/Section.astro';
import PageTitle from '@components/PageTitle.astro';
import Button from '@components/Button.astro';
import { exhibitors } from '@lib/exhibitors';


import titleSVG from '@assets/map/title.svg';

const floors = [
  { id: 'B2', label: 'B2F', available: true },
  { id: 'B1', label: 'B1F', available: true },
  { id: '1', label: '1F', available: true },
  { id: '2', label: '2F', available: true },
];

const eventDays = ['4/10', '4/11'] as const;
const circleBoothDetailsByBooth = Object.fromEntries(
  Array.from({ length: 19 }, (_, index) => [
    `circle-booth-${index + 1}`,
    Object.fromEntries(eventDays.map((day) => [day, null])) as Record<
      (typeof eventDays)[number],
      { type: string; title: string; organizer: string } | null
    >,
  ])
);

for (const exhibitor of exhibitors) {
  if (!exhibitor.booths.includes('サークルブース')) continue;
  const location = exhibitor.circleBoothLocation?.trim();
  if (!location) continue;

  const boothId = `circle-booth-${location}`;
  const detail = {
    type: 'サークルブース',
    title: exhibitor.circleBoothTitle?.trim() || exhibitor.exhibitorName,
    organizer: exhibitor.exhibitorName,
  };
  const activeDays = exhibitor.circleBoothDate?.length ? exhibitor.circleBoothDate : exhibitor.days;

  for (const day of activeDays) {
    if (!circleBoothDetailsByBooth[boothId]) continue;
    if (!circleBoothDetailsByBooth[boothId][day]) {
      circleBoothDetailsByBooth[boothId][day] = detail;
    }
  }
}
---

<Layout title="マップ">
  <Section>
    <PageTitle titleSVG={titleSVG} />
    <p class="text-body">
      ボタンを押してフロアを切り替えられます。マップは拡大できます（Ctrl + ホイール、ピンチ、PCはドラッグで移動）
    </p>
  </Section>

  <section class="map-full-section">
    <div class="map-shell">
      <div class="floor-tabs" role="tablist" aria-label="フロア選択">
        {floors.map((floor) => (
          <button
            type="button"
            class:list={['floor-tab', !floor.available && 'is-unavailable']}
            role="tab"
            data-floor-button
            data-floor={floor.id}
            data-available={String(floor.available)}
          >
            <span>{floor.label}</span>
            {!floor.available && <span class="floor-tab-meta">準備中</span>}
          </button>
        ))}
      </div>

      <div class="map-stage">
        <p id="map-status" class="map-status" aria-live="polite"></p>
        <div id="map-container" class="map-container" role="tabpanel" tabindex="0"></div>
        <dialog id="booth-modal" class="booth-modal">
          <article class="booth-modal-card">
            <div class="booth-modal-handle" aria-hidden="true"></div>
            <button type="button" class="booth-modal-close" data-booth-modal-close aria-label="閉じる">×</button>
            <h2 id="booth-modal-title" class="booth-modal-title"></h2>
            <p id="booth-modal-subtitle" class="booth-modal-subtitle"></p>
            <p id="booth-modal-type" class="booth-type-tag"></p>
            <div class="booth-modal-row">
              <p id="booth-modal-detail-label" class="booth-modal-label">開催日ごとの内容</p>
              <div id="booth-modal-schedule" class="booth-modal-schedule"></div>
              <div id="booth-modal-timetable-link" class="booth-modal-timetable-link" hidden>
                <Button href="/timetable/" text="タイムテーブルを見る" />
              </div>
            </div>
          </article>
        </dialog>
      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ circleBoothDetailsByBooth }}>
  const buttons = Array.from(document.querySelectorAll('[data-floor-button]'));
  const mapContainer = document.getElementById('map-container');
  const mapStatus = document.getElementById('map-status');
  const boothModal = document.getElementById('booth-modal');
  const boothModalType = document.getElementById('booth-modal-type');
  const boothModalTitle = document.getElementById('booth-modal-title');
  const boothModalSubtitle = document.getElementById('booth-modal-subtitle');
  const boothModalDetailLabel = document.getElementById('booth-modal-detail-label');
  const boothModalSchedule = document.getElementById('booth-modal-schedule');
  const boothModalTimetableLink = document.getElementById('booth-modal-timetable-link');
  const boothModalCard = boothModal?.querySelector('.booth-modal-card');
  const boothModalCloseButton = boothModal?.querySelector('[data-booth-modal-close]');

  const MIN_ZOOM = 0.75;
  const MAX_ZOOM = 4;
  const ZOOM_STEP = 0.25;
  const MOBILE_DEFAULT_MAP_ZOOM = 1.45;
  const DESKTOP_DEFAULT_MAP_ZOOM = 1.2;
  const MOBILE_FOCUS_ZOOM = 2.1;
  const DESKTOP_FOCUS_ZOOM = 1.65;
  const MAP_BG_FILL = '#fff8fb';
  let zoomLevel = 1;
  let pinchStartDistance = null;
  let pinchStartZoom = 1;
  let modalTouchStartY = null;
  let isMousePanning = false;
  let panStartX = 0;
  let panStartY = 0;
  let panStartScrollLeft = 0;
  let panStartScrollTop = 0;
  let activeBoothId = null;
  const EVENT_DAYS = ['4/10', '4/11'];
  const DAY_LABEL = {
    '4/10': '4/10(金)',
    '4/11': '4/11(土)',
  };
  const urlParams = new URLSearchParams(location.search);
  let requestedBoothId = urlParams.get('booth');
  const requestedBoothInfo = {
    type: urlParams.get('boothType'),
    title: urlParams.get('boothTitle'),
    organizer: urlParams.get('boothOrganizer'),
  };

  const DEFAULT_BOOTH_ORGANIZER = '出展団体（調整中）';
  const STATIC_BOOTH_DETAIL_MAP = new Map([
    [
      'booth-boardgame',
      {
        type: 'TPG企画',
        title: 'ボードゲーム紹介',
        description: 'ボードゲームを楽しみながら交流できるコーナーです！',
      },
    ],
    [
      'booth-pingpong',
      {
        type: 'TPG企画',
        title: 'キムワイプ卓球',
        description: '理系なら一度はやってみたい！？キムワイプを使って卓球をしよう！',
      },
    ],
    [
      'booth-workshop-1',
      {
        type: 'ワークショップ企画',
        title: 'Attic Lab',
        description: 'ワークショップ企画の説明文（仮）です。',
      },
    ],
    [
      'booth-workshop-2',
      {
        type: 'ワークショップ企画',
        title: 'Attic Office',
        description: 'ワークショップ企画の説明文（仮）です。',
      },
    ],
    [
      'booth-takiplazastage',
      {
        type: 'ステージ企画',
        title: 'ステージ企画',
        description: 'ステージ企画の説明文（仮）です。',
      },
    ],
    [
      'booth-kitchen',
      {
        type: 'キッチンエリア',
        title: 'キッチンエリア',
        description: 'キッチンエリアの説明文です。',
      },
    ],
  ]);

  const buildCircleBoothDetails = () =>
    Array.from({ length: 19 }, (_, index) => {
      const boothNo = index + 1;
      const id = `circle-booth-${boothNo}`;
      const dayDetails = circleBoothDetailsByBooth?.[id] ?? {};
      const featured = dayDetails['4/10'] ?? dayDetails['4/11'] ?? null;
      return [
        id,
        {
          type: featured?.type ?? 'サークルブース',
          title: featured?.title ?? `サークルブース ${boothNo}`,
          organizer: featured?.organizer ?? DEFAULT_BOOTH_ORGANIZER,
        },
      ];
    });
  const boothDetailMap = new Map(buildCircleBoothDetails());

  const floorState = new Map(
    buttons.map((button) => [
      button.dataset.floor,
      { available: button.dataset.available === 'true' },
    ])
  );

  const floorOrder = buttons
    .map((button) => button.dataset.floor)
    .filter((floor) => typeof floor === 'string');
  const firstAvailableFloor =
    floorOrder.find((floor) => floorState.get(floor)?.available) ?? floorOrder[0];

  const normalizeFloor = (value) => (floorState.has(value) ? value : firstAvailableFloor);

  const getFloorLabel = (floor) => {
    const button = buttons.find((item) => item.dataset.floor === floor);
    return button ? button.querySelector('span')?.textContent ?? `${floor}F` : `${floor}F`;
  };

  const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

  const applyZoom = () => {
    const svg = mapContainer?.querySelector('svg');
    if (svg instanceof SVGElement) {
      svg.style.width = `${Math.round(zoomLevel * 100)}%`;
      svg.style.maxWidth = 'none';
      svg.style.height = 'auto';
    }
    requestAnimationFrame(() => renderFacilityLabels());
  };

  const setZoom = (nextZoom) => {
    zoomLevel = clamp(Math.round(nextZoom * 100) / 100, MIN_ZOOM, MAX_ZOOM);
    applyZoom();
  };

  const getTouchDistance = (touches) => {
    const [touchA, touchB] = touches;
    return Math.hypot(touchA.clientX - touchB.clientX, touchA.clientY - touchB.clientY);
  };

  const resetZoom = () => {
    zoomLevel = window.matchMedia('(max-width: 767px)').matches
      ? MOBILE_DEFAULT_MAP_ZOOM
      : DESKTOP_DEFAULT_MAP_ZOOM;
    applyZoom();
  };

  const centerMapViewport = (behavior = 'auto') => {
    if (!mapContainer) return;
    const maxLeft = Math.max(mapContainer.scrollWidth - mapContainer.clientWidth, 0);
    const maxTop = Math.max(mapContainer.scrollHeight - mapContainer.clientHeight, 0);
    mapContainer.scrollTo({
      left: maxLeft / 2,
      top: maxTop / 2,
      behavior,
    });
  };

  let currentFloor = normalizeFloor(new URLSearchParams(location.search).get('floor'));

  const setActiveButton = (floor) => {
    buttons.forEach((button) => {
      const isActive = button.dataset.floor === floor;
      button.classList.toggle('active', isActive);
      button.setAttribute('aria-selected', String(isActive));
      button.tabIndex = isActive ? 0 : -1;
    });
  };

  const updateHistory = (floor, mode) => {
    if (mode === 'none') return;

    const url = new URL(location.href);
    url.searchParams.set('floor', floor);
    if (mode === 'replace') {
      history.replaceState({ floor }, '', url);
      return;
    }
    history.pushState({ floor }, '', url);
  };

  const updateBoothQuery = (boothId, mode = 'replace') => {
    const url = new URL(location.href);
    if (boothId) {
      url.searchParams.set('booth', boothId);
    } else {
      url.searchParams.delete('booth');
    }
    url.searchParams.delete('boothType');
    url.searchParams.delete('boothTitle');
    url.searchParams.delete('boothOrganizer');

    if (mode === 'push') {
      history.pushState({}, '', url);
      return;
    }
    history.replaceState({}, '', url);
  };

  const formatBoothLabel = (boothId) => {
    const matched = boothId.match(/^circle-booth-(\d+)$/);
    if (boothId === 'booth-takiplazastage') return 'Taki Plaza ステージ';
    if (!matched) return STATIC_BOOTH_DETAIL_MAP.get(boothId)?.title ?? boothId;
    return `サークルブース ${matched[1]}`;
  };

  const getBoothDetail = (boothId, overrides = {}) => {
    const preset = boothDetailMap.get(boothId) ?? STATIC_BOOTH_DETAIL_MAP.get(boothId) ?? {};

    let fallbackType = 'サークルブース';
    if (boothId.startsWith('workshop-')) fallbackType = 'ワークショップ';
    if (boothId.startsWith('boardgame-')) fallbackType = 'ボードゲーム紹介';
    if (boothId.startsWith('kimwipe-')) fallbackType = 'キムワイプ卓球';
    if (boothId === 'booth-boardgame') fallbackType = 'ボードゲーム紹介';
    if (boothId === 'booth-pingpong') fallbackType = 'キムワイプ卓球';
    if (boothId.startsWith('booth-workshop-')) fallbackType = 'ワークショップ企画';

    return {
      type: overrides.type ?? preset.type ?? fallbackType,
      title: overrides.title ?? preset.title ?? formatBoothLabel(boothId),
      organizer: overrides.organizer ?? preset.organizer ?? DEFAULT_BOOTH_ORGANIZER,
      description: overrides.description ?? preset.description ?? '説明準備中です。',
    };
  };

  const getBoothDayDetails = (boothId) => circleBoothDetailsByBooth?.[boothId] ?? {};

  const escapeHtml = (value) =>
    String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

  const renderBoothSchedule = (boothId, overrides = {}) => {
    if (!boothModalSchedule || !boothModalTimetableLink) return;

    if (overrides.title || overrides.organizer) {
      boothModalTimetableLink.hidden = true;
      const title = escapeHtml(overrides.title ?? formatBoothLabel(boothId));
      const organizer = escapeHtml(overrides.organizer ?? DEFAULT_BOOTH_ORGANIZER);
      boothModalSchedule.innerHTML = `
        <div class="booth-schedule-item">
          <p class="booth-schedule-title">${title}</p>
          <p class="booth-schedule-day">展示情報</p>
          <p class="booth-schedule-organizer">運営: ${organizer}</p>
        </div>
      `;
      return;
    }

    if (!boothId.startsWith('circle-booth-')) {
      boothModalSchedule.innerHTML = '';
      boothModalTimetableLink.hidden = false;
      return;
    }

    boothModalTimetableLink.hidden = true;
    const dayDetails = getBoothDayDetails(boothId);
    boothModalSchedule.innerHTML = EVENT_DAYS.map((day) => {
      const detail = dayDetails?.[day];
      const title = escapeHtml(detail?.title ?? '展示調整中');
      const organizer = escapeHtml(detail?.organizer ?? DEFAULT_BOOTH_ORGANIZER);
      const dayLabel = escapeHtml(DAY_LABEL[day] ?? day);
      return `
        <div class="booth-schedule-item">
          <p class="booth-schedule-title">${title}</p>
          <p class="booth-schedule-day">${dayLabel}</p>
          <p class="booth-schedule-organizer">運営: ${organizer}</p>
        </div>
      `;
    }).join('');
  };

  const getBoothElements = () =>
    Array.from(
      mapContainer?.querySelectorAll(
        '[id^="circle-booth-"], [id^="booth-workshop-"], #booth-boardgame, #booth-pingpong, #booth-takiplazastage, #booth-kitchen'
      ) ?? []
    ).filter(
      (el) => el instanceof SVGGraphicsElement
    );

  const renderFacilityLabels = () => {
    if (!mapContainer) return;
    const svg = mapContainer.querySelector('svg');
    if (!(svg instanceof SVGSVGElement)) return;

    svg.querySelector('#facility-label-layer')?.remove();
    const layer = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    layer.setAttribute('id', 'facility-label-layer');
    layer.setAttribute('pointer-events', 'none');

    const facilityDefs = [
      { ids: ['ev', 'elevator'], label: 'エレベーター', icon: '/maps/elevator.svg' },
      { ids: ['toilet'], label: 'トイレ', icon: '/maps/wc.svg' },
      { ids: ['reception'], label: '受付', icon: null },
    ];

    const findTargets = (ids) => {
      const targets = [];
      const seen = new Set();
      ids.forEach((id) => {
        const selector = `#${id}, [id^="${id}_"], [id^="${id}-"]`;
        svg.querySelectorAll(selector).forEach((el) => {
          if (!(el instanceof SVGGraphicsElement)) return;
          if (seen.has(el)) return;
          seen.add(el);
          targets.push(el);
        });
      });
      return targets;
    };

    facilityDefs.forEach((facility) => {
      const targets = findTargets(facility.ids);
      if (!targets.length) return;

      const viewBox = svg.viewBox.baseVal;
      const svgRect = svg.getBoundingClientRect();
      const pxPerUnit = viewBox?.width ? svgRect.width / viewBox.width : 1;
      const unitsPerPx = 1 / Math.max(pxPerUnit, 0.0001);
      const iconSize = 34 * unitsPerPx;
      const iconYOffset = 5 * unitsPerPx;
      const textSize = 10 * unitsPerPx;
      const textStroke = 1.8 * unitsPerPx;
      const textY = facility.icon ? 9 * unitsPerPx : 2.5 * unitsPerPx;
      const labelWidth = Math.max(42, facility.label.length * 10) * unitsPerPx;
      const labelHeight = 16 * unitsPerPx;
      const topY = facility.icon
        ? -(iconSize + iconYOffset)
        : textY - labelHeight / 2;
      const bottomY = textY + labelHeight / 2;
      const markerOffsetY = -((topY + bottomY) / 2);

      targets.forEach((target) => {
        const bbox = target.getBBox();
        const cx = bbox.x + bbox.width / 2;
        const cy = bbox.y + bbox.height / 2;

        const marker = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        marker.setAttribute('class', 'facility-label');
        marker.setAttribute('transform', `translate(${cx} ${cy + markerOffsetY})`);
        if (facility.icon) {
          const icon = document.createElementNS('http://www.w3.org/2000/svg', 'image');
          icon.setAttribute('href', facility.icon);
          icon.setAttribute('x', String(-iconSize / 2));
          icon.setAttribute('y', String(-(iconSize + iconYOffset)));
          icon.setAttribute('width', String(iconSize));
          icon.setAttribute('height', String(iconSize));
          icon.setAttribute('class', 'facility-icon');
          marker.appendChild(icon);
        }
        const labelBg = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        labelBg.setAttribute('x', String(-labelWidth / 2));
        labelBg.setAttribute('y', String(textY - labelHeight / 2));
        labelBg.setAttribute('width', String(labelWidth));
        labelBg.setAttribute('height', String(labelHeight));
        labelBg.setAttribute('rx', String(5 * unitsPerPx));
        labelBg.setAttribute('fill', '#fff8fb');
        labelBg.setAttribute('fill-opacity', '0.92');
        marker.appendChild(labelBg);

        const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        text.setAttribute('x', '0');
        text.setAttribute('y', String(textY));
        text.setAttribute('text-anchor', 'middle');
        text.setAttribute('dominant-baseline', 'middle');
        text.setAttribute('class', 'facility-text');
        text.style.fontSize = `${textSize}px`;
        text.style.strokeWidth = `${textStroke}px`;
        text.style.fill = '#3e2e33';
        text.style.stroke = '#fff8fb';
        text.style.paintOrder = 'stroke fill';
        text.style.fontWeight = '800';
        text.textContent = facility.label;
        marker.appendChild(text);
        layer.appendChild(marker);
      });
    });

    svg.appendChild(layer);
  };

  const BOOTH_TYPE_STYLE = {
    'サークルブース': { fill: '#ff7ba7', hoverFill: '#ff5b95', stroke: '#ffffff' },
    'ワークショップ企画': { fill: '#ffb36b', hoverFill: '#ff9b42', stroke: '#ffffff' },
    ワークショップ: { fill: '#ffb36b', hoverFill: '#ff9b42', stroke: '#ffffff' },
    TPG企画: { fill: '#7ddf8f', hoverFill: '#57cc6d', stroke: '#ffffff' },
    'ステージ企画': { fill: '#6fb8ff', hoverFill: '#489ff5', stroke: '#ffffff' },
    'キッチンエリア': { fill: '#b48cff', hoverFill: '#9c6fff', stroke: '#ffffff' },
    'ボードゲーム紹介': { fill: '#7ddf8f', hoverFill: '#57cc6d', stroke: '#ffffff' },
    'キムワイプ卓球': { fill: '#7ddf8f', hoverFill: '#57cc6d', stroke: '#ffffff' },
  };

  const getBoothStyle = (boothEl) =>
    BOOTH_TYPE_STYLE[boothEl.dataset.boothType ?? ''] ?? BOOTH_TYPE_STYLE['サークルブース'];

  const applyDefaultBoothStyle = (boothEl) => {
    const style = getBoothStyle(boothEl);
    boothEl.style.opacity = '0.96';
    boothEl.style.fill = style.fill;
    boothEl.style.stroke = style.stroke;
    boothEl.style.strokeWidth = '2';
    boothEl.style.filter = '';
  };

  const applyHoverBoothStyle = (boothEl) => {
    const style = getBoothStyle(boothEl);
    boothEl.style.opacity = '1';
    boothEl.style.fill = style.hoverFill;
    boothEl.style.stroke = style.stroke;
    boothEl.style.strokeWidth = '2';
  };

  const clearActiveBooth = () => {
    const mapCanvas = mapContainer?.querySelector('.map-canvas');
    mapCanvas?.classList.remove('has-active-booth');
    getBoothElements().forEach((el) => {
      el.classList.remove('is-active-booth');
      applyDefaultBoothStyle(el);
    });
    if (!activeBoothId) return;
    const activeEl = mapContainer?.querySelector(`#${activeBoothId}`);
    activeEl?.classList.remove('is-active-booth');
    activeBoothId = null;
  };

  const closeBoothModal = ({ clearQuery = true } = {}) => {
    if (boothModal?.open) {
      boothModal.close();
    }
    boothModal?.classList.remove('is-expanded');
    modalTouchStartY = null;
    if (boothModalCard instanceof HTMLElement) {
      boothModalCard.scrollTop = 0;
    }
    clearActiveBooth();
    if (clearQuery) {
      updateBoothQuery(null, 'replace');
    }
  };

  const centerBoothInView = (boothEl, behavior = 'smooth') => {
    if (!mapContainer) return;
    const bounds = boothEl.getBoundingClientRect();
    const containerBounds = mapContainer.getBoundingClientRect();
    const offsetX = bounds.left - containerBounds.left + mapContainer.scrollLeft;
    const offsetY = bounds.top - containerBounds.top + mapContainer.scrollTop;
    mapContainer.scrollTo({
      left: Math.max(offsetX - mapContainer.clientWidth / 2 + bounds.width / 2, 0),
      top: Math.max(offsetY - mapContainer.clientHeight / 2 + bounds.height / 2, 0),
      behavior,
    });
  };

  const openBoothModal = (
    boothId,
    { syncUrl = true, detailOverrides = {}, centerBehavior = 'smooth', applyFocusZoom = true } = {}
  ) => {
    if (
      !mapContainer ||
      !boothModal ||
      !boothModalType ||
      !boothModalTitle ||
      !boothModalSubtitle ||
      !boothModalSchedule
    ) {
      return;
    }
    const boothEl = mapContainer.querySelector(`#${boothId}`);
    if (!(boothEl instanceof SVGGraphicsElement)) {
      mapStatus.textContent = `指定されたブース (${boothId}) は見つかりませんでした。`;
      return;
    }

    const boothDetail = getBoothDetail(boothId, detailOverrides);
    clearActiveBooth();
    const mapCanvas = mapContainer.querySelector('.map-canvas');
    mapCanvas?.classList.add('has-active-booth');
    getBoothElements().forEach((el) => {
      el.style.opacity = '0.35';
      el.style.filter = '';
    });
    boothEl.classList.add('is-active-booth');
    boothEl.style.opacity = '1';
    boothEl.style.fill = '#f9004b';
    boothEl.style.stroke = '#91002f';
    boothEl.style.strokeWidth = '3';
    boothEl.style.filter = 'drop-shadow(0 0 10px rgba(249, 0, 75, 0.65))';
    activeBoothId = boothId;
    const isCircleBooth = boothId.startsWith('circle-booth-');
    const dayDetails = getBoothDayDetails(boothId);
    const dayTitlePairs = EVENT_DAYS.map((day) => ({
      day,
      title: dayDetails?.[day]?.title ?? null,
    })).filter((item) => item.title);
    const uniqueTitles = Array.from(new Set(dayTitlePairs.map((item) => item.title)));
    const dayTitleText =
      uniqueTitles.length === 1
        ? uniqueTitles[0]
        : dayTitlePairs.length
          ? dayTitlePairs.map((item) => `${DAY_LABEL[item.day]} ${item.title}`).join(' / ')
          : null;
    const modalTitle =
      detailOverrides.title ??
      dayTitleText ??
      boothDetail.title ??
      formatBoothLabel(boothId);

    boothModalType.textContent = detailOverrides.type ?? boothDetail.type;
    boothModalTitle.textContent = modalTitle;
    boothModalSubtitle.textContent = formatBoothLabel(boothId);
    if (boothModalDetailLabel) {
      boothModalDetailLabel.textContent = isCircleBooth ? '開催日ごとの内容' : 'タイムテーブル';
    }
    renderBoothSchedule(boothId, detailOverrides);

    const focusZoom = window.matchMedia('(max-width: 767px)').matches
      ? MOBILE_FOCUS_ZOOM
      : DESKTOP_FOCUS_ZOOM;
    if (applyFocusZoom && zoomLevel < focusZoom) {
      setZoom(focusZoom);
    }
    boothModal?.classList.remove('is-expanded');
    modalTouchStartY = null;
    if (boothModalCard instanceof HTMLElement) {
      boothModalCard.scrollTop = 0;
    }
    centerBoothInView(boothEl, centerBehavior);
    requestAnimationFrame(() => centerBoothInView(boothEl, 'auto'));

    if (!boothModal.open) {
      boothModal.showModal();
    }
    if (syncUrl) {
      updateBoothQuery(boothId, 'replace');
    }
  };

  const bindBoothInteractions = () => {
    const boothElements = Array.from(
      mapContainer?.querySelectorAll(
        '[id^="circle-booth-"], [id^="booth-workshop-"], #booth-boardgame, #booth-pingpong, #booth-takiplazastage, #booth-kitchen'
      ) ?? []
    );
    boothElements.forEach((boothEl) => {
      if (!(boothEl instanceof SVGElement)) return;
      const boothType = getBoothDetail(boothEl.id).type;
      boothEl.dataset.boothType = boothType;
      applyDefaultBoothStyle(boothEl);
      boothEl.classList.add('is-clickable-booth');
      boothEl.setAttribute('tabindex', '0');
      boothEl.setAttribute('role', 'button');
      boothEl.setAttribute('aria-label', `${formatBoothLabel(boothEl.id)}を開く`);
      boothEl.addEventListener('mouseenter', () => {
        if (boothEl.id === activeBoothId) return;
        applyHoverBoothStyle(boothEl);
      });
      boothEl.addEventListener('mouseleave', () => {
        if (boothEl.id === activeBoothId) return;
        applyDefaultBoothStyle(boothEl);
      });
      boothEl.addEventListener('focus', () => {
        if (boothEl.id === activeBoothId) return;
        applyHoverBoothStyle(boothEl);
      });
      boothEl.addEventListener('blur', () => {
        if (boothEl.id === activeBoothId) return;
        applyDefaultBoothStyle(boothEl);
      });
      boothEl.addEventListener('click', () => openBoothModal(boothEl.id));
      boothEl.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        event.preventDefault();
        openBoothModal(boothEl.id);
      });
    });
  };

  const renderUnavailable = (floor) => {
    mapContainer.innerHTML = `
      <div class="map-placeholder">
        <p class="map-placeholder-title">${getFloorLabel(floor)} のマップは準備中です</p>
        <p class="map-placeholder-text">現在公開されている他フロアのマップをご確認ください。</p>
      </div>
    `;
    resetZoom();
    closeBoothModal({ clearQuery: false });
    mapStatus.textContent = `${getFloorLabel(floor)} は準備中です。`;
  };

  const renderError = (floor) => {
    mapContainer.innerHTML = `
      <div class="map-placeholder map-placeholder-error">
        <p class="map-placeholder-title">${getFloorLabel(floor)} のマップを読み込めませんでした</p>
        <p class="map-placeholder-text">時間をおいて再度お試しください。</p>
      </div>
    `;
    resetZoom();
    closeBoothModal({ clearQuery: false });
    mapStatus.textContent = `${getFloorLabel(floor)} の読み込みに失敗しました。`;
  };

  const renderFloor = async (floor, historyMode = 'push') => {
    if (!mapContainer || !mapStatus || !floorState.has(floor)) return;

    currentFloor = floor;
    setActiveButton(floor);
    updateHistory(floor, historyMode);

    if (!floorState.get(floor)?.available) {
      renderUnavailable(floor);
      return;
    }

    mapStatus.textContent = `${getFloorLabel(floor)} を読み込み中...`;
    try {
      const response = await fetch(`/maps/floor-${floor}.svg`);
      if (!response.ok) {
        throw new Error(`Failed to load floor map: ${floor}`);
      }
      const svg = await response.text();
      mapContainer.innerHTML = `<div class="map-canvas">${svg}</div>`;
      const mapBackground = mapContainer.querySelector('#bg');
      if (mapBackground instanceof SVGElement) {
        mapBackground.setAttribute('fill', MAP_BG_FILL);
        mapBackground.style.fill = MAP_BG_FILL;
      }
      renderFacilityLabels();
      resetZoom();
      bindBoothInteractions();
      if (requestedBoothId) {
        openBoothModal(requestedBoothId, {
          syncUrl: true,
          detailOverrides: requestedBoothInfo,
          centerBehavior: 'auto',
        });
        requestedBoothId = null;
      } else {
        requestAnimationFrame(() => centerMapViewport('auto'));
      }
      mapStatus.textContent = `${getFloorLabel(floor)} を表示中`;
    } catch {
      renderError(floor);
    }
  };

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      const floor = button.dataset.floor;
      if (!floor || floor === currentFloor) return;
      renderFloor(normalizeFloor(floor));
    });
  });

  window.addEventListener('popstate', () => {
    const floor = normalizeFloor(new URLSearchParams(location.search).get('floor'));
    if (floor === currentFloor) return;
    renderFloor(floor, 'none');
  });

  mapContainer?.addEventListener(
    'wheel',
    (event) => {
      if (!event.ctrlKey && !event.metaKey) return;
      event.preventDefault();
      setZoom(zoomLevel + (event.deltaY < 0 ? ZOOM_STEP / 2 : -ZOOM_STEP / 2));
    },
    { passive: false }
  );

  mapContainer?.addEventListener(
    'touchstart',
    (event) => {
      if (event.touches.length !== 2) return;
      event.preventDefault();
      pinchStartDistance = getTouchDistance(event.touches);
      pinchStartZoom = zoomLevel;
    },
    { passive: false }
  );

  mapContainer?.addEventListener(
    'touchmove',
    (event) => {
      if (event.touches.length !== 2 || pinchStartDistance === null) return;
      event.preventDefault();
      const nextDistance = getTouchDistance(event.touches);
      if (pinchStartDistance <= 0) return;
      setZoom(pinchStartZoom * (nextDistance / pinchStartDistance));
    },
    { passive: false }
  );

  mapContainer?.addEventListener('touchend', (event) => {
    if (event.touches.length < 2) {
      pinchStartDistance = null;
    }
  });

  mapContainer?.addEventListener('touchcancel', () => {
    pinchStartDistance = null;
  });

  window.addEventListener('resize', () => {
    requestAnimationFrame(() => renderFacilityLabels());
  });

  const preventGesture = (event) => {
    event.preventDefault();
  };
  mapContainer?.addEventListener('gesturestart', preventGesture);
  mapContainer?.addEventListener('gesturechange', preventGesture);
  mapContainer?.addEventListener('gestureend', preventGesture);

  mapContainer?.addEventListener('mousedown', (event) => {
    if (event.button !== 0) return;
    isMousePanning = true;
    panStartX = event.clientX;
    panStartY = event.clientY;
    panStartScrollLeft = mapContainer.scrollLeft;
    panStartScrollTop = mapContainer.scrollTop;
    mapContainer.classList.add('is-dragging');
  });

  window.addEventListener('mousemove', (event) => {
    if (!isMousePanning || !mapContainer) return;
    event.preventDefault();
    const deltaX = event.clientX - panStartX;
    const deltaY = event.clientY - panStartY;
    mapContainer.scrollLeft = panStartScrollLeft - deltaX;
    mapContainer.scrollTop = panStartScrollTop - deltaY;
  });

  window.addEventListener('mouseup', () => {
    if (!isMousePanning || !mapContainer) return;
    isMousePanning = false;
    mapContainer.classList.remove('is-dragging');
  });

  boothModalCloseButton?.addEventListener('click', () => {
    closeBoothModal();
  });

  boothModal?.addEventListener('click', (event) => {
    if (event.target === boothModal) {
      closeBoothModal();
    }
  });

  boothModal?.addEventListener('close', () => {
    boothModal?.classList.remove('is-expanded');
    modalTouchStartY = null;
    if (boothModalCard instanceof HTMLElement) {
      boothModalCard.scrollTop = 0;
    }
    clearActiveBooth();
    updateBoothQuery(null, 'replace');
  });

  boothModalCard?.addEventListener('scroll', () => {
    if (!(boothModalCard instanceof HTMLElement)) return;
    if (boothModalCard.scrollTop > 8) {
      boothModal?.classList.add('is-expanded');
    }
  });

  boothModalCard?.addEventListener(
    'touchstart',
    (event) => {
      if (!(boothModalCard instanceof HTMLElement)) return;
      if (event.touches.length !== 1) return;
      modalTouchStartY = event.touches[0].clientY;
    },
    { passive: true }
  );

  boothModalCard?.addEventListener(
    'touchmove',
    (event) => {
      if (!(boothModalCard instanceof HTMLElement) || modalTouchStartY === null) return;
      if (boothModal?.classList.contains('is-expanded')) return;
      if (event.touches.length !== 1) return;
      const deltaY = event.touches[0].clientY - modalTouchStartY;
      if (deltaY < -18) {
        boothModal?.classList.add('is-expanded');
      }
    },
    { passive: true }
  );

  boothModalCard?.addEventListener('touchend', () => {
    modalTouchStartY = null;
  });

  renderFloor(currentFloor, 'replace');
</script>

