---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import Section from '@components/layout/Section.astro';
import SectionTitle from '@components/SectionTitle.astro';
import BoothCard from '@components/BoothCard.astro';
import Button from '@components/Button.astro';
import FaqAccordion from '@components/FaqAccordion.astro';

import { boothData } from '@lib/booth';


import HeadingAbout from '@assets/heading/about.svg';
import HeadingBooth from '@assets/heading/booth.svg';
import HeadingFAQ from '@assets/heading/faq.svg';
import HeadingHost from '@assets/heading/host.svg';

const faqItems = [
  {
    question: '若葉祭はいつ開催されますか？',
    answer: '2026年4月10日(金)・11日(土)に開催されます。',
  },
  {
    question: '会場はどこですか？',
    answer: 'Taki Plazaおよび70周年記念講堂で開催されます。',
    links: [{ label: 'マップを見る', href: '/map' }],
  },
  {
    question: 'どんな企画がありますか？',
    answer: 'サークルブース、ワークショップ、ステージ企画など、さまざまな新歓企画があります。',
    links: [{ label: '出展団体一覧を見る', href: '/exhibitors' }],
  },
  {
    question: '途中から参加しても大丈夫ですか？',
    answer: 'はい、途中参加・途中退出も可能です。授業や予定の合間に気軽にお越しください。',
  },
  {
    question: 'このイベントの主催団体は？',
    answer: 'Taki Plazaにおいて、国際交流と学生支援の促進を目的に活動している公認学生団体TPGが運営しています。また、蔵前工業会のご支援もいただいています。',
    links: [{ label: 'TPG公式サイトを見る', href: 'https://tpgd.jp/' }],
  },
];
---

<Layout title="トップ">
  <Hero />
  <Section>
    <SectionTitle headingSVG={HeadingAbout} alt="若葉祭とは" />
    <p class="text-body">若葉祭は、Taki Plaza Gardener (TPG) が主催する学内最大規模のサークル合同新歓イベントです！約40の団体が一同に会し、新歓活動を行います。今年度は4月10日(金)・11日(土)にTaki Plazaおよび70周年記念講堂で開催されます。TPGによる企画も多数ありますので、授業終わりなどに気軽にお越しください！</p>
  </Section>
  <Section>
    <SectionTitle headingSVG={HeadingBooth} alt="出展団体" />
    <div class="booths-wrapper" id="booth">
      {boothData.map((booth) => (
        <BoothCard {...booth} />
      ))}
    </div>
  </Section>
  <Section>
    <SectionTitle headingSVG={HeadingHost} alt="主催団体" />
    <p class="text-body">Taki Plaza Gardener(TPG)は、東京科学大学にあるHisao & Hiroko Taki Plazaにおいて、国際交流と学生支援の促進を目的に活動している公認学生団体です。</p>
    <p class="text-body">TPGは、学生がTaki Plazaをもっと身近に、もっと活発に利用できるよう、年間を通してさまざまな学生向けイベントを企画・運営しています。なかでも「若葉祭」は、学内最大級の新入生向けイベントとして、多くの学生が参加するTPGの代表的な企画です。</p>
    <p class="text-body">少しでもTPGに興味を持った方は、ぜひTaki Plaza 地下2階の居室へお越しください！皆さんの参加をお待ちしています。</p>
    <Button href="https://tpgd.jp/" text="TPG公式サイトを見る" />
  </Section>
  <Section>
    <SectionTitle headingSVG={HeadingFAQ} alt="よくある質問" />
    <FaqAccordion items={faqItems} />
  </Section>
</Layout>

<style>
  .booths-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    justify-content: center;
    margin-top: 20px;
  }
</style>
