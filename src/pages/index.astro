---
import Layout from '@layouts/Layout.astro';
import { Image } from 'astro:assets';
import landingBg from '@assets/landing_bg.png';
import wakabasaiLogo from '@assets/wakabasai_logo.svg';
---

<Layout title="Coming Soon">
  <main>
    <Image src={landingBg} alt="" class="bg" />
    <div class="overlay">
      <div class="content">
        <Image src={wakabasaiLogo} alt="若葉祭 2026" class="logo" />
        <p class="coming-soon">Coming Soon</p>
        <p class="date">4.10 <span>fri</span> – 4.11 <span>sat</span></p>
        <p class="sns-label">最新情報はSNSをチェック！</p>
        <div class="sns">
          <a href="https://x.com/tpgardener" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L2.019 2.25H8.08l4.253 5.622L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/taki_plaza_gardener" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </a>
          <a href="https://www.tpgd.jp/" target="_blank" rel="noopener noreferrer" aria-label="TPG Website">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
              <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.22.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  main {
    position: relative;
    width: 100vw;
    height: 100dvh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .overlay {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(2px);
  }

  .content {
    text-align: center;
    padding: 2rem;
    font-family: 'Noto Sans JP Variable', 'Noto Sans JP', sans-serif;
  }

  .logo {
    display: block;
    width: clamp(180px, 40vw, 320px);
    height: auto;
    margin: 0 auto 1.25rem;
  }

  .coming-soon {
    font-size: clamp(0.7rem, 2vw, 0.85rem);
    color: #666;
    margin: 0 0 1.25rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    font-weight: 400;
  }

  .date {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: #1a1a1a;
    margin: 0 0 2rem;
    letter-spacing: 0.15em;
    font-weight: 500;
  }

  .date span {
    font-size: 0.75em;
    letter-spacing: 0.05em;
    opacity: 0.7;
  }

  .sns-label {
    font-size: clamp(0.75rem, 2vw, 0.9rem);
    color: #444;
    margin: 0 0 0.75rem;
    letter-spacing: 0.1em;
  }

  .sns {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    align-items: center;
  }

  .sns a {
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1a1a1a;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.6);
    transition: background 0.2s, transform 0.2s;
    text-decoration: none;
  }

  .sns a:hover {
    background: rgba(255, 255, 255, 0.9);
    transform: scale(1.1);
  }
</style>
