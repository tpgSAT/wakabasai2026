---
interface Props {
    text: string;
    href: string;
}

const { text, href } = Astro.props as Props;
---
<a class="btn" href={href} >
    {text}
</a>

<style>
    .btn {
        display: inline-block;
        width: 100%;
        text-align: center;
        box-sizing: border-box;
        padding: 8px 12px;
        margin-top: 10px;
        text-decoration: none;

        font-size: 14px;
        font-style: normal;
        font-weight: 500;
        line-height: 191%;
        letter-spacing: 0.96px;

        color: #fff;
        background-color: var(--wakabasai-red);
    }
</style>