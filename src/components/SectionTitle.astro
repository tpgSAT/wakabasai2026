---
import type { ImageMetadata } from 'astro'
import { Image } from 'astro:assets';

interface Props {
  headingSVG: ImageMetadata;
  alt?: string;
}

const { headingSVG, alt = "セクションタイトル" } = Astro.props as Props;
---

<div class="section-title">
  <Image src={headingSVG} alt={alt} />
</div>

<style>
  .section-title {
    display: inline-block;
    height: clamp(40px, 12vw, 60px);
    width: auto;
  }

  .section-title img {
    height: 100%;
    width: auto;
  }
</style>
