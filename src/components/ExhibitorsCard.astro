---
import type { exhibitor } from "@lib/exhibitors";
import { Image } from "astro:assets";
import Button from "@components/Button.astro";

import xIcon from "@assets/exhibitors/x.svg";
import instagramIcon from "@assets/exhibitors/instagram.svg";

const { exhibitorName, exhibitorDescription, exhibitorIcon, exhibitorPhoto, booths, xLink, instagramLink, youtubeLink, websiteLink } = Astro.props as exhibitor;

const LIMIT = 40;
const isLong = exhibitorDescription.length > LIMIT;
const shortDescription = isLong ? exhibitorDescription.slice(0, LIMIT) + "…" : exhibitorDescription;
---
<div class="exhibitor-card">
    <div class="exhibitor-header">
        <Image src={exhibitorIcon} alt={`${exhibitorName}のアイコン`} class="exhibitor-icon" />
        <div class="sns-wrapper">
            {xLink && (
                <a href={xLink} target="_blank" rel="noopener noreferrer">
                    <Image src={xIcon} alt="X" class="sns-icon" />
                </a>
            )}
            {instagramLink && (
                <a href={instagramLink} target="_blank" rel="noopener noreferrer">
                    <Image src={instagramIcon} alt="Instagram" class="sns-icon" />
                </a>
            )}
        </div>
        <h3>{exhibitorName}</h3>
        <div class="booth-wrapper">
            {booths.map((booth, index) => (
                <p key={index} class="booth-tag">{booth}</p>
            ))}
        </div>
        <p class="text-body description-short">{shortDescription}</p>
        {(isLong || exhibitorPhoto)&& (
            <>
             <div class="description-full" hidden>
                {exhibitorPhoto && (
                    <Image src={exhibitorPhoto} alt={`${exhibitorName}の写真`} class="exhibitor-photo" />
                )}
                <p class="text-body">{exhibitorDescription}</p>
            </div>
            <Button text="詳細を見る" style="outlined" class="details-btn" />
            </>
        )}
    </div>
</div>

<script>
    document.querySelectorAll('.details-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const card = btn.closest('.exhibitor-card')!;
            const short = card.querySelector('.description-short') as HTMLElement;
            const full = card.querySelector('.description-full') as HTMLElement;
            const isExpanded = !full.hidden;
            full.hidden = isExpanded;
            short.hidden = !isExpanded;
            btn.textContent = isExpanded ? '詳細を見る' : '閉じる';
        });
    });</script>

<style>
    .exhibitor-card {
        display: flex;
        flex-direction: column;
        padding: 12px;
        width: min(100%, 350px);
        background-color: #DBDBDB;
        box-sizing: border-box;
        margin: 30px 0;
    }

    .exhibitor-header {
        display: flex;
        flex-direction: column;
        position: relative;
    }

    .sns-wrapper {
        display: flex;
        flex-direction: row;
        justify-content: flex-end;
        gap: 12px;
        margin: 5px 5px 0 0;
        min-height: 28px;
    }

    .sns-icon {
        width: 28px;
        height: 28px;
    }

    .exhibitor-icon {
        width: 80px;
        height: 80px;
        object-fit: cover;
        margin-bottom: 12px;
        position: absolute;
        top: -50px;
        left: 0px;
        border-style: solid;
        border-width: 2px 8px 8px 2px;
        border-color: var(--wakabasai-red);
        background-color: #fff;
    }

    .exhibitor-header h3 {
        margin: 20px 0 0;
        font-size: 20px;
        font-style: normal;
        font-weight: 700;
        line-height: normal;
        letter-spacing: 2px;
    }

    .booth-wrapper {
        display: flex;
        gap: 8px;
        margin: 8px 0;
        flex-wrap: wrap;
    }

    .booth-tag {
        background-color: var(--wakabasai-red);
        color: #fff;
        padding: 4px 8px;
        margin: 0;
        font-size: 12px;
    }

    .details-btn {
        align-self: flex-start;
    }

    .exhibitor-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        margin-bottom: 8px;
    }
</style>